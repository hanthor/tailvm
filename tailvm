def _apply_manifest(manifest: dict) -> None:
    """Write manifest to a temp file and kubectl apply it."""
    with tempfile.NamedTemporaryFile(
        mode="w", suffix=".yaml", delete=False,
    ) as f:
        json.dump(manifest, f, indent=2)
        tmp_path = f.name
    try:
        subprocess.run(
            ["kubectl", "apply", "-f", tmp_path],
            check=True, capture_output=True, text=True,
        )
    except subprocess.CalledProcessError as e:
        print_error(f"kubectl apply failed:\n{e.stderr.strip()}")
        sys.exit(1)
    finally:
        os.unlink(tmp_path)


# ── YAML output helper (for manifests; we write JSON but kubectl is fine with it) ──

def _to_yaml(manifest: dict) -> str:
    """Convert a manifest dict to YAML string (requires PyYAML)."""
    try:
        import yaml

        return yaml.dump(manifest, default_flow_style=False, sort_keys=False)
    except ImportError:
        # Fallback: output as JSON (kubectl accepts both)
        return json.dumps(manifest, indent=2)


# ═══════════════════════════════════════════════════════════════════
#  Dispatcher — route to correct backend
# ═══════════════════════════════════════════════════════════════════

# Map of (command, backend) → handler
_QEMU_CMDS: dict[str, object] = {
    "create": cmd_qemu_create,
    "start": cmd_qemu_start,
    "stop": cmd_qemu_stop,
    "list": cmd_qemu_list,
    "info": cmd_qemu_info,
    "delete": cmd_qemu_delete,
    "viewer": cmd_qemu_viewer,
    "eject": cmd_qemu_eject,
    "logs": cmd_qemu_logs,
}

_KUBEVIRT_CMDS: dict[str, object] = {
    "create": cmd_kubevirt_create,
    "start": cmd_kubevirt_start,
    "stop": cmd_kubevirt_stop,
    "list": cmd_kubevirt_list,
    "info": cmd_kubevirt_info,
    "delete": cmd_kubevirt_delete,
    "viewer": cmd_kubevirt_viewer,
    "logs": cmd_kubevirt_logs,
}


def _dispatch(command: str, args: argparse.Namespace) -> None:
    """Route the command to the correct backend handler."""
    if command == "create":
        # Create: use the flag or default to qemu
        backend = "kubevirt" if args.kubevirt else "qemu"
        handler = (_KUBEVIRT_CMDS if backend == "kubevirt" else _QEMU_CMDS)[command]
    elif command == "list":
        # List: show both backends
        cmd_qemu_list()
        print()  # separator
        cmd_kubevirt_list()
        return
    else:
        # All other commands: resolve backend from registry
        backend = require_backend(args.name)
        cmds = _KUBEVIRT_CMDS if backend == "kubevirt" else _QEMU_CMDS
        if command not in cmds:
            print_error(f"Command '{command}' is not supported for backend '{backend}'.")
            sys.exit(1)
        handler = cmds[command]

    handler(args)


# ═══════════════════════════════════════════════════════════════════
#  CLI definition
# ═══════════════════════════════════════════════════════════════════

def main() -> None:
    parser = argparse.ArgumentParser(
        description=(
            f"{Colors.BOLD}TailVM{Colors.ENDC} — Spin up and manage "
            "QEMU/KubeVirt VMs with secure VNC access over Tailscale."
        ),
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    sub = parser.add_subparsers(dest="command", help="Subcommand")

    # ── create ──
    p_create = sub.add_parser("create", help="Create a new virtual machine")
    p_create.add_argument("name", help="Name of the VM")
    p_create.add_argument(
        "--kubevirt", "-k", action="store_true",
        help="Use KubeVirt backend (Kubernetes) instead of local QEMU",
    )
    # Shared flags
    p_create.add_argument("--mem", default="4G", help="Memory (default: 4G)")
    p_create.add_argument("--cpu", type=int, default=2, help="CPU cores (default: 2)")
    # QEMU-only flags
    p_create.add_argument("--iso", default=None, help="[QEMU] ISO path/URL")
    p_create.add_argument("--qcow", default=None, help="[QEMU] QCOW2 template path/URL")
    p_create.add_argument("--disk", default=None, help="Disk size (default: 20G)")
    p_create.add_argument("--force", action="store_true", help="[QEMU] Overwrite existing VM")
    # KubeVirt-only flags
    p_create.add_argument(
        "--container-disk", default=None,
        help="[KubeVirt] Container disk image (e.g. quay.io/containerdisks/ubuntu:24.04)",
    )
    p_create.add_argument(
        "--pvc", default=None,
        help="[KubeVirt] Existing PVC to use as boot disk",
    )
    p_create.add_argument(
        "--namespace", "-n", default="default",
        help="[KubeVirt] Kubernetes namespace (default: default)",
    )
    p_create.add_argument(
        "--node", default=None,
        help="[KubeVirt] Schedule on specific node (e.g. karnataka)",
    )
    p_create.add_argument(
        "--cloud-init-password", default=None,
        help="[KubeVirt] Cloud-init password (random if not set)",
    )

    # ── start ──
    p_start = sub.add_parser("start", help="Start a virtual machine")
    p_start.add_argument("name", help="Name of the VM")
    p_start.add_argument("--no-viewer", action="store_true", help="Don't launch viewer")

    # ── stop ──
    p_stop = sub.add_parser("stop", help="Stop a virtual machine")
    p_stop.add_argument("name", help="Name of the VM")

    # ── list ──
    sub.add_parser("list", help="List all virtual machines (both backends)")

    # ── info ──
    p_info = sub.add_parser("info", help="Show details of a virtual machine")
    p_info.add_argument("name", help="Name of the VM")

    # ── delete ──
    p_delete = sub.add_parser("delete", help="Delete a virtual machine and its files")
    p_delete.add_argument("name", help="Name of the VM")

    # ── viewer ──
    p_viewer = sub.add_parser("viewer", help="Launch VNC viewer for a running VM")
    p_viewer.add_argument("name", help="Name of the VM")

    # ── eject (QEMU only) ──
    p_eject = sub.add_parser("eject", help="Eject ISO from VM (QEMU only)")
    p_eject.add_argument("name", help="Name of the VM")

    # ── logs ──
    p_logs = sub.add_parser("logs", help="View logs for the VM service/launcher")
    p_logs.add_argument("name", help="Name of the VM")

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        sys.exit(0)

    try:
        _dispatch(args.command, args)
    except KeyboardInterrupt:
        print_warning("\nInterrupted.")
        sys.exit(130)


if __name__ == "__main__":
    main()
