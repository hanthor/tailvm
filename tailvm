def cmd_kubevirt_create(args: argparse.Namespace) -> None:
    name = args.name
    ns = args.namespace or "default"
    password = args.cloud_init_password or _random_password()

    # Build and apply PVCs first if needed
    has_container = bool(args.container_disk)
    has_existing_pvc = bool(args.pvc)

    if has_existing_pvc:
        # Use existing PVC — no new PVCs needed
        pass
    elif has_container:
        # Container disk: create data PVC if --disk given
        if args.disk:
            pvc = generate_pvc_manifest(f"{name}-data", ns, args.disk)
            _apply_manifest(pvc)
            print_info(f"Created data PVC: {name}-data ({args.disk})")
    else:
        # Default: empty boot PVC
        disk_size = args.disk or "20G"
        pvc = generate_pvc_manifest(f"{name}-disk", ns, disk_size)
        _apply_manifest(pvc)
        print_info(f"Created boot PVC: {name}-disk ({disk_size})")

    # Build VM manifest
    manifest = generate_kubevirt_vm_manifest(
        name=name,
        namespace=ns,
        cpu=args.cpu,
        mem=args.mem,
        container_disk=args.container_disk,
        pvc_name=args.pvc,
        disk_size=args.disk if has_container else None,
        cloud_init_password=password,
    )

    # Add nodeSelector if specified
    if args.node:
        manifest["spec"]["template"]["spec"]["nodeSelector"] = {
            "kubernetes.io/hostname": args.node,
        }

    _apply_manifest(manifest)

    registry_set(name, "kubevirt", {
        "namespace": ns,
        "cloud_init_password": password,
    })

    print_success(f"KubeVirt VM '{name}' created in namespace '{ns}'!")
    if not has_container:
        print_info(f"Cloud-init password: {Colors.BOLD}{password}{Colors.ENDC}")
        print_info("  (save this — it won't be shown again)")
    print_info(f"Start it:  tailvm start {name}")


def cmd_kubevirt_start(args: argparse.Namespace) -> None:
    name = args.name
    ns = _kubevirt_namespace(name)
    print_info(f"Starting KubeVirt VM '{name}' …")
    virtctl = _ensure_virtctl()
    subprocess.run([virtctl, "start", name, "-n", ns], check=True)
    print_success(f"VM '{name}' started!")

    # Check if VMI is running
    try:
        res = _kubectl(["get", "vmi", name, "-n", ns, "-o", "json"])
        if res.returncode == 0:
            vmi = json.loads(res.stdout)
            phase = vmi.get("status", {}).get("phase", "unknown")
            print_info(f"VMI phase: {phase}")
    except Exception:
        pass

    if not args.no_viewer:
        print_info("Use 'tailvm viewer {name}' for VNC, or:")
        print_info(f"  virtctl vnc {name} -n {ns}")


def cmd_kubevirt_stop(args: argparse.Namespace) -> None:
    name = args.name
    ns = _kubevirt_namespace(name)
    print_info(f"Stopping KubeVirt VM '{name}' …")
    virtctl = _ensure_virtctl()
    subprocess.run([virtctl, "stop", name, "-n", ns], check=True)
    print_success(f"VM '{name}' stopped.")


def cmd_kubevirt_list() -> None:
    try:
        res = _kubectl(["get", "vms", "-A", "-o", "json"])
        if res.returncode != 0:
            print_info("No KubeVirt VMs found (or kubectl unavailable).")
            return
        vms = json.loads(res.stdout).get("items", [])
    except (FileNotFoundError, json.JSONDecodeError):
        print_info("kubectl not available — skipping KubeVirt VMs.")
        return

    if not vms:
        return  # Don't print "no VMs" — local QEMU may have some

    print(
        f"{Colors.BOLD}"
        f"{'VM NAME':<20} {'BACKEND':<10} {'STATUS':<14} {'NAMESPACE':<14} "
        f"{'CPU':<5} {'MEM':<8} {'NODE'}"
        f"{Colors.ENDC}"
    )
    print("-" * 85)
    for vm in vms:
        md = vm.get("metadata", {})
        name = md.get("name", "?")
        ns = md.get("namespace", "?")
        spec = vm.get("spec", {})
        tmpl = spec.get("template", {}).get("spec", {})
        dom = tmpl.get("domain", {})
        cpu = dom.get("cpu", {}).get("cores", "?")
        mem = dom.get("memory", {}).get("guest", "?")
        node = tmpl.get("nodeSelector", {}).get(
            "kubernetes.io/hostname", "—"
        )

        running = vm.get("status", {}).get("ready", False)
        run_str = f"{Colors.OKGREEN}Running{Colors.ENDC}" if running else "Stopped"

        print(
            f"{name:<20} {'kubevirt':<10} {run_str:<22} {ns:<14} "
            f"{cpu:<5} {mem:<8} {node}"
        )


def cmd_kubevirt_info(args: argparse.Namespace) -> None:
    name = args.name
    ns = _kubevirt_namespace(name)
    entry = registry_get(name)

    print(f"{Colors.BOLD}--- VM Info: {name} (KubeVirt) ---{Colors.ENDC}")
    print(f"Namespace:    {ns}")

    # VM info
    try:
        res = _kubectl(["get", "vm", name, "-n", ns, "-o", "json"])
        if res.returncode == 0:
            vm = json.loads(res.stdout)
            spec = vm.get("spec", {})
            tmpl = spec.get("template", {}).get("spec", {})
            dom = tmpl.get("domain", {})
            cpu = dom.get("cpu", {}).get("cores", "?")
            mem = dom.get("memory", {}).get("guest", "?")
            running = spec.get("running", False)
            ready = vm.get("status", {}).get("ready", False)

            status_str = (
                f"{Colors.OKGREEN}Running{Colors.ENDC}" if ready
                else f"{Colors.OKCYAN}Pending{Colors.ENDC}" if running
                else "Stopped"
            )
            print(f"Status:       {status_str}")
            print(f"CPU Cores:    {cpu}")
            print(f"Memory:       {mem}")
            print(f"Running spec: {running}")

            # Volumes
            vols = tmpl.get("volumes", [])
            for v in vols:
                vname = v.get("name", "?")
                if "containerDisk" in v:
                    print(f"ContainerDisk:{v['containerDisk'].get('image', '?')}")
                elif "persistentVolumeClaim" in v:
                    print(f"PVC ({vname}): {v['persistentVolumeClaim'].get('claimName', '?')}")
    except Exception:
        print_warning("Could not fetch VM details from cluster.")

    # VMI info (if running)
    try:
        res = _kubectl(["get", "vmi", name, "-n", ns, "-o", "json"])
        if res.returncode == 0:
            vmi = json.loads(res.stdout)
            phase = vmi.get("status", {}).get("phase", "?")
            node = vmi.get("status", {}).get("nodeName", "?")
            print(f"VMI Phase:    {phase}")
            print(f"Node:         {node}")
    except Exception:
        pass

    if entry and "cloud_init_password" in entry:
        print(f"Cloud-init:   password={entry['cloud_init_password']}")

    print(f"\n{Colors.BOLD}VNC:{Colors.ENDC}  virtctl vnc {name} -n {ns}")


def cmd_kubevirt_delete(args: argparse.Namespace) -> None:
    name = args.name
    ns = _kubevirt_namespace(name)

    print_info(f"Deleting KubeVirt VM '{name}' in namespace '{ns}' …")
    try:
        virtctl = _ensure_virtctl()
        subprocess.run([virtctl, "stop", name, "-n", ns], capture_output=True)
    except Exception:
        pass

    # Delete the VM
    _kubectl(["delete", "vm", name, "-n", ns, "--ignore-not-found"])

    # Delete associated PVCs
    for pvc_suffix in ["disk", "data"]:
        pvc_name = f"{name}-{pvc_suffix}"
        try:
            res = _kubectl([
                "delete", "pvc", pvc_name, "-n", ns, "--ignore-not-found",
            ])
            if res.returncode == 0 and "deleted" in (res.stdout + res.stderr):
                print_info(f"Deleted PVC: {pvc_name}")
        except Exception:
            pass

    registry_remove(name)
    print_success(f"VM '{name}' deleted.")


def cmd_kubevirt_viewer(args: argparse.Namespace) -> None:
    name = args.name
    ns = _kubevirt_namespace(name)
    virtctl = _ensure_virtctl()
    print_info(f"Launching VNC for '{name}' via virtctl …")
    os.execvp(virtctl, [virtctl, "vnc", name, "-n", ns])


def cmd_kubevirt_logs(args: argparse.Namespace) -> None:
    name = args.name
    ns = _kubevirt_namespace(name)
    # Find the virt-launcher pod
    try:
        res = _kubectl([
            "get", "pods", "-n", ns,
            "-l", f"kubevirt.io/vm={name}",
            "-o", "jsonpath={.items[0].metadata.name}",
        ])
        pod = res.stdout.strip()
        if not pod:
            print_error(f"No virt-launcher pod found for VM '{name}'.")
            sys.exit(1)
        print_info(f"Tailing logs for pod/{pod} …")
        subprocess.run([
            "kubectl", "logs", "-f", pod, "-n", ns,
        ])
    except KeyboardInterrupt:
        print()
    except Exception as e:
        print_error(f"Failed to get logs: {e}")


