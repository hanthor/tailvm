#!/usr/bin/env python3
"""
TailVM — Spin up and manage QEMU/KubeVirt VMs with secure VNC access.

Usage: tailvm create|start|stop|list|info|delete|viewer|eject|logs [args...]

Backends:
  qemu      Local QEMU/KVM via systemd user services (default)
  kubevirt  Kubernetes VMs via KubeVirt CRDs

When --kubevirt is passed to create, the choice is persisted and all subsequent
commands (start, stop, viewer, …) know which backend to use without flags.
"""
import sys
import os
import argparse
import subprocess
import shutil
import socket
import json
import time
import string
import secrets
import tempfile
from pathlib import Path

# ── Paths ────────────────────────────────────────────────────────
HOME = Path.home()
BASE_DIR = HOME / "tailvms"
CACHE_DIR = BASE_DIR / "cache"
SYSTEMD_USER_DIR = HOME / ".config" / "systemd" / "user"
REGISTRY_DIR = HOME / ".local" / "share" / "tailvm"
REGISTRY_FILE = REGISTRY_DIR / "registry.json"


# ── CLI colours ──────────────────────────────────────────────────
class Colors:
    HEADER    = "\033[95m"
    OKBLUE    = "\033[94m"
    OKCYAN    = "\033[96m"
    OKGREEN   = "\033[92m"
    WARNING   = "\033[93m"
    FAIL      = "\033[91m"
    ENDC      = "\033[0m"
    BOLD      = "\033[1m"
    UNDERLINE = "\033[4m"


def _cprint(color: str, prefix: str, msg: str) -> None:
    print(f"{color}{prefix} {msg}{Colors.ENDC}")


def print_success(msg: str) -> None:
    _cprint(Colors.OKGREEN, "✔", msg)


def print_info(msg: str) -> None:
    _cprint(Colors.OKCYAN, "ℹ", msg)


def print_warning(msg: str) -> None:
    _cprint(Colors.WARNING, "⚠", msg)


def print_error(msg: str) -> None:
    _cprint(Colors.FAIL, "✘", msg)


# ═══════════════════════════════════════════════════════════════════
#  Registry — persist which backend each VM uses
# ═══════════════════════════════════════════════════════════════════

def _load_registry() -> dict:
    """Read the VM registry file, returning {} if it doesn't exist."""
    if not REGISTRY_FILE.exists():
        return {}
    try:
        with open(REGISTRY_FILE, "r") as f:
            return json.load(f)
    except (json.JSONDecodeError, OSError):
        return {}


def _save_registry(reg: dict) -> None:
    """Atomically write the registry file."""
    REGISTRY_DIR.mkdir(parents=True, exist_ok=True)
    tmp = REGISTRY_FILE.with_suffix(".tmp")
    with open(tmp, "w") as f:
        json.dump(reg, f, indent=2)
    tmp.rename(REGISTRY_FILE)


def registry_set(name: str, backend: str, extra: dict | None = None) -> None:
    """Record a VM in the registry."""
    reg = _load_registry()
    reg[name] = {"backend": backend, **(extra or {})}
    _save_registry(reg)


def registry_get(name: str) -> dict | None:
    """Return the registry entry for *name*, or None."""
    return _load_registry().get(name)


def registry_remove(name: str) -> None:
    """Remove a VM from the registry."""
    reg = _load_registry()
    reg.pop(name, None)
    _save_registry(reg)


def registry_list() -> dict:
    """Return the full registry."""
    return _load_registry()


# ═══════════════════════════════════════════════════════════════════
#  Helpers shared across backends
# ═══════════════════════════════════════════════════════════════════

def resolve_backend(name: str) -> str | None:
    """
    Determine the backend for a VM.
    1. Check registry first.
    2. If not in registry, check if it exists as a KubeVirt VM.
    3. If not, check if it exists locally on disk.
    """
    entry = registry_get(name)
    if entry:
        return entry["backend"]

    # Heuristic: check kubectl first (cleaner), then local filesystem
    if _kubevirt_vm_exists(name):
        return "kubevirt"
    if (BASE_DIR / name).exists():
        return "qemu"
    return None


def require_backend(name: str) -> str:
    """Resolve the backend or die with a helpful message."""
    backend = resolve_backend(name)
    if backend is None:
        print_error(
            f"VM '{name}' does not exist (not in registry or on disk / cluster)."
        )
        sys.exit(1)
    return backend


# ── KubeVirt helpers ─────────────────────────────────────────────

def _kubectl(args: list[str], **kwargs) -> subprocess.CompletedProcess:
    """Run kubectl with default text capturing."""
    defaults = {"capture_output": True, "text": True}
    defaults.update(kwargs)
    return subprocess.run(
        ["kubectl"] + args, **defaults  # type: ignore[arg-type]
    )


def _kubevirt_vm_exists(name: str, namespace: str = "default") -> bool:
    """Check if a VirtualMachine exists in the cluster."""
    try:
        res = _kubectl(
            ["get", "vm", name, "-n", namespace, "-o", "name"],
        )
        return res.returncode == 0
    except FileNotFoundError:
        return False


def _ensure_virtctl() -> str:
    """Return path to virtctl, installing it if missing."""
    path = shutil.which("virtctl")
    if path:
        return path

    # Try to install via brew if available
    brew = shutil.which("brew")
    if brew:
        print_info("virtctl not found — installing via Homebrew …")
        try:
            subprocess.run(
                [brew, "install", "kubevirt-cli"],
                check=True, capture_output=True, text=True,
            )
            path = shutil.which("virtctl")
            if path:
                print_success("virtctl installed.")
                return path
        except subprocess.CalledProcessError as e:
            print_error(f"brew install kubevirt-cli failed: {e.stderr.strip()}")
            sys.exit(1)

    print_error(
        "virtctl is required for KubeVirt VNC access. "
        "Install it: brew install kubevirt-cli"
    )
    sys.exit(1)


def _kubevirt_namespace(name: str) -> str:
    """Return the namespace stored in the registry, defaulting to 'default'."""
    entry = registry_get(name)
    if entry:
        return entry.get("namespace", "default")
    return "default"


# ── Tailscale helpers ────────────────────────────────────────────

def get_tailscale_ip() -> str | None:
    """Retrieves the host's Tailscale IPv4 address."""
    path = shutil.which("tailscale")
    if path:
        try:
            res = subprocess.run(
                [path, "ip", "-4"], capture_output=True, text=True, check=True,
            )
            ip = res.stdout.strip()
            if ip:
                return ip
        except Exception:
            pass
    # Fallback: scan tailscale0
    try:
        res = subprocess.run(
            ["ip", "-4", "addr", "show", "dev", "tailscale0"],
            capture_output=True, text=True,
        )
        for line in res.stdout.split("\n"):
            if "inet " in line:
                return line.split()[1].split("/")[0]
    except Exception:
        pass
    return None


# ── QEMU helpers ─────────────────────────────────────────────────

def find_qemu_binaries() -> tuple[str | None, str | None]:
    """Find qemu-system-x86_64 and qemu-img, with a Homebrew fallback."""
    qemu = shutil.which("qemu-system-x86_64")
    qemu_img = shutil.which("qemu-img")
    hb = Path("/home/linuxbrew/.linuxbrew/bin")
    if not qemu and (hb / "qemu-system-x86_64").exists():
        qemu = str(hb / "qemu-system-x86_64")
    if not qemu_img and (hb / "qemu-img").exists():
        qemu_img = str(hb / "qemu-img")
    return qemu, qemu_img


# ── VNC port management (QEMU backend) ──────────────────────────

def get_assigned_displays() -> set[int]:
    displays: set[int] = set()
    if not BASE_DIR.exists():
        return displays
    for item in BASE_DIR.iterdir():
        if not item.is_dir():
            continue
        meta = item / "metadata.json"
        if meta.exists():
            try:
                data = json.loads(meta.read_text())
                if "vnc_display" in data:
                    displays.add(int(data["vnc_display"]))
            except Exception:
                pass
    return displays


def find_free_vnc_display(ip: str) -> int:
    assigned = get_assigned_displays()
    display = 1
    while True:
        if display in assigned:
            display += 1
            continue
        port = 5900 + display
        try:
            with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
                s.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
                s.bind((ip if ip else "0.0.0.0", port))
                return display
        except OSError:
            display += 1


# ── File downloads ───────────────────────────────────────────────

def download_file(url: str, dest: Path) -> None:
    """Download *url* to *dest* with a progress bar."""
    import urllib.request

    print_info(f"Downloading: {url}")
    CACHE_DIR.mkdir(parents=True, exist_ok=True)
    tmp = dest.with_suffix(".tmp")

    try:
        req = urllib.request.Request(
            url, headers={"User-Agent": "Mozilla/5.0"}
        )
        with urllib.request.urlopen(req) as resp:
            total = int(resp.info().get("Content-Length", 0))
            blk = 64 * 1024
            dled = 0
            with open(tmp, "wb") as f:
                while True:
                    buf = resp.read(blk)
                    if not buf:
                        break
                    dled += len(buf)
                    f.write(buf)
                    if total > 0:
                        pct = dled * 100 / total
                        bar_w = 30
                        fill = int(bar_w * dled // total)
                        bar = "=" * fill + "-" * (bar_w - fill)
                        print(
                            f"\r  [{bar}] {pct:.1f}% "
                            f"({dled / (1024*1024):.1f} MB / "
                            f"{total / (1024*1024):.1f} MB)",
                            end="", flush=True,
                        )
                    else:
                        print(
                            f"\r  Downloaded: {dled / (1024*1024):.1f} MB",
                            end="", flush=True,
                        )
            print()
        if tmp.exists():
            tmp.rename(dest)
        print_success("Download complete and cached!")
    except Exception as e:
        if tmp.exists():
            tmp.unlink(missing_ok=True)
        print_error(f"Download failed: {e}")
        sys.exit(1)


def resolve_source(source_str: str | None) -> str | None:
    """Resolve a local path or remote URL; download + cache if remote."""
    if not source_str:
        return None
    if source_str.startswith(("http://", "https://")):
        from urllib.parse import urlparse
        import hashlib

        parsed = urlparse(source_str)
        filename = os.path.basename(parsed.path) or hashlib.md5(
            source_str.encode()
        ).hexdigest()
        cached = CACHE_DIR / filename
        if cached.exists():
            print_success(f"Using cached image: {cached.name}")
            return str(cached)
        download_file(source_str, cached)
        return str(cached)
    lp = Path(source_str).resolve()
    if not lp.exists():
        print_error(f"Local file does not exist: {lp}")
        sys.exit(1)
    return str(lp)


# ── systemd unit generation (QEMU backend) ──────────────────────

def generate_systemd_unit(
    name: str,
    qemu_path: str,
    mem: str,
    cpu: int,
    disk_path: str,
    iso_path: str | None,
    tailscale_ip: str,
    vnc_display: int,
    has_iso: bool,
) -> str:
    iso_args = f"-cdrom {iso_path} -boot once=d,menu=on" if has_iso and iso_path else ""
    vnc_target = (
        f"{tailscale_ip}:{vnc_display}" if tailscale_ip else f"127.0.0.1:{vnc_display}"
    )
    return f"""[Unit]
Description=TailVM Virtual Machine - {name}
After=network.target

[Service]
Type=simple
WorkingDirectory={BASE_DIR / name}
ExecStart={qemu_path} \\
  -enable-kvm \\
  -cpu host \\
  -smp {cpu} \\
  -m {mem} \\
  -drive file={disk_path},if=virtio,cache=writeback \\
  {iso_args} \\
  -vnc {vnc_target} \\
  -vga virtio \\
  -device virtio-net-pci,netdev=net0 \\
  -netdev user,id=net0
Restart=on-failure

[Install]
WantedBy=default.target
"""


def daemon_reload() -> None:
    subprocess.run(["systemctl", "--user", "daemon-reload"], check=True)


# ═══════════════════════════════════════════════════════════════════
#  KubeVirt VM manifest generation
# ═══════════════════════════════════════════════════════════════════

def _random_password(length: int = 16) -> str:
    alphabet = string.ascii_letters + string.digits
    return "".join(secrets.choice(alphabet) for _ in range(length))


def generate_kubevirt_vm_manifest(
    name: str,
    namespace: str,
    cpu: int,
    mem: str,
    container_disk: str | None,
    pvc_name: str | None,
    disk_size: str | None,
    cloud_init_password: str | None,
) -> dict:
    """Build a KubeVirt VirtualMachine manifest dict."""
    mem_val = mem.upper()
    # Strip the 'G'/'M' suffix and convert to Mi for the VM spec
    if mem_val.endswith("G"):
        mem_mib = int(mem_val[:-1]) * 1024
    elif mem_val.endswith("M"):
        mem_mib = int(mem_val[:-1])
    else:
        mem_mib = int(mem_val)  # assume Mi

    domain: dict = {
        "cpu": {"cores": cpu},
        "memory": {"guest": f"{mem_mib}Mi"},
        "devices": {"disks": []},
    }
    volumes: list[dict] = []

    # --- Primary boot disk ---
    if container_disk:
        volumes.append({
            "name": "containerdisk",
            "containerDisk": {"image": container_disk},
        })
        domain["devices"]["disks"].append({
            "name": "containerdisk",
            "disk": {"bus": "virtio"},
        })
    elif pvc_name:
        volumes.append({
            "name": "rootdisk",
            "persistentVolumeClaim": {"claimName": pvc_name},
        })
        domain["devices"]["disks"].append({
            "name": "rootdisk",
            "disk": {"bus": "virtio"},
        })
    else:
        # Default: empty PVC (blank disk)
        claim_name = f"{name}-disk"
        volumes.append({
            "name": "rootdisk",
            "persistentVolumeClaim": {"claimName": claim_name},
        })
        domain["devices"]["disks"].append({
            "name": "rootdisk",
            "disk": {"bus": "virtio"},
        })

    # --- Data disk (PVC created separately) ---
    if disk_size and container_disk:
        # Attach an additional data PVC when using container disk + --disk
        data_claim = f"{name}-data"
        volumes.append({
            "name": "datadisk",
            "persistentVolumeClaim": {"claimName": data_claim},
        })
        domain["devices"]["disks"].append({
            "name": "datadisk",
            "disk": {"bus": "virtio"},
        })

    # --- Cloud-init ---
    pwd = cloud_init_password or _random_password()
    cloud_init_userdata = (
        "#cloud-config\n"
        f"password: {pwd}\n"
        "chpasswd:\n  expire: False\n"
        "ssh_pwauth: true\n"
    )
    volumes.append({
        "name": "cloudinitdisk",
        "cloudInitNoCloud": {"userData": cloud_init_userdata},
    })
    domain["devices"]["disks"].append({
        "name": "cloudinitdisk",
        "disk": {"bus": "virtio"},
    })

    return {
        "apiVersion": "kubevirt.io/v1",
        "kind": "VirtualMachine",
        "metadata": {
            "name": name,
            "namespace": namespace,
            "labels": {"tailvm": name},
        },
        "spec": {
            "running": False,
            "template": {
                "metadata": {"labels": {"kubevirt.io/vm": name}},
                "spec": {
                    "domain": domain,
                    "volumes": volumes,
                },
            },
        },
    }


def generate_pvc_manifest(
    name: str,
    namespace: str,
    size: str,
    storage_class: str = "local-path",
) -> dict:
    """Build a PersistentVolumeClaim manifest."""
    return {
        "apiVersion": "v1",
        "kind": "PersistentVolumeClaim",
        "metadata": {
            "name": name,
            "namespace": namespace,
            "labels": {"tailvm": name.rsplit("-", 1)[0]},
        },
        "spec": {
            "accessModes": ["ReadWriteOnce"],
            "resources": {"requests": {"storage": size}},
            "storageClassName": storage_class,
        },
    }


# ═══════════════════════════════════════════════════════════════════
#  COMMANDS  —  QEMU backend (local)
# ═══════════════════════════════════════════════════════════════════

def cmd_qemu_create(args: argparse.Namespace) -> None:
    qemu_path, qemu_img_path = find_qemu_binaries()
    if not qemu_path or not qemu_img_path:
        print_error("QEMU binaries not found. Install qemu: brew install qemu")
        sys.exit(1)

    vm_dir = BASE_DIR / args.name
    if vm_dir.exists() and not args.force:
        print_error(
            f"VM directory {vm_dir} already exists. "
            "Use --force to overwrite."
        )
        sys.exit(1)

    ip = get_tailscale_ip()
    if not ip:
        print_warning("Tailscale IP not found; defaulting VNC to localhost.")
        ip = "127.0.0.1"
    else:
        print_info(f"Using Tailscale IP: {ip}")

    resolved_iso = resolve_source(args.iso) if args.iso else None
    resolved_qcow = resolve_source(args.qcow) if args.qcow else None

    display = find_free_vnc_display(ip)
    port = 5900 + display
    print_info(f"Allocating VNC display :{display} (Port {port})")

    vm_dir.mkdir(parents=True, exist_ok=True)
    SYSTEMD_USER_DIR.mkdir(parents=True, exist_ok=True)

    disk_path = vm_dir / "disk.qcow2"

    if resolved_qcow:
        print_info(f"Copying QCOW2 template to {disk_path} …")
        shutil.copy2(resolved_qcow, disk_path)
        os.chmod(disk_path, 0o644)
        if args.disk:
            print_info(f"Resizing disk to {args.disk} …")
            subprocess.run(
                [qemu_img_path, "resize", str(disk_path), args.disk],
                check=True, capture_output=True,
            )
    else:
        disk_size = args.disk or "20G"
        print_info(f"Creating {disk_size} QCOW2 virtual disk …")
        subprocess.run(
            [qemu_img_path, "create", "-f", "qcow2",
             str(disk_path), disk_size],
            check=True, capture_output=True,
        )

    service_path = SYSTEMD_USER_DIR / f"tailvm-{args.name}.service"
    service_content = generate_systemd_unit(
        name=args.name,
        qemu_path=qemu_path,
        mem=args.mem,
        cpu=args.cpu,
        disk_path=str(disk_path),
        iso_path=resolved_iso,
        tailscale_ip=ip,
        vnc_display=display,
        has_iso=bool(resolved_iso),
    )
    service_path.write_text(service_content)

    metadata = {
        "name": args.name,
        "iso": resolved_iso,
        "has_iso": bool(resolved_iso),
        "qcow_template": resolved_qcow,
        "disk_size": args.disk
        or ("Template Default" if resolved_qcow else "20G"),
        "memory": args.mem,
        "cpu": args.cpu,
        "vnc_display": display,
        "vnc_port": port,
        "tailscale_ip": ip,
        "created_at": time.strftime("%Y-%m-%dT%H:%M:%S"),
    }
    (vm_dir / "metadata.json").write_text(json.dumps(metadata, indent=2))

    registry_set(args.name, "qemu", {"namespace": "default"})
    daemon_reload()
    print_success(f"VM '{args.name}' created!")
    print_info(f"Start it:  tailvm start {args.name}")


def cmd_qemu_start(args: argparse.Namespace) -> None:
    name = args.name
    vm_dir = BASE_DIR / name
    svc = f"tailvm-{name}"
    svc_path = SYSTEMD_USER_DIR / f"{svc}.service"

    if not vm_dir.exists() or not svc_path.exists():
        print_error(f"VM '{name}' does not exist!")
        sys.exit(1)

    meta = json.loads((vm_dir / "metadata.json").read_text())
    vnc_url = f"vnc://{meta['tailscale_ip']}:{meta['vnc_port']}"

    res = subprocess.run(
        ["systemctl", "--user", "is-active", svc],
        capture_output=True, text=True,
    )
    if res.stdout.strip() == "active":
        print_info(f"VM '{name}' is already running.")
    else:
        print_info(f"Starting VM '{name}' …")
        subprocess.run(["systemctl", "--user", "start", svc], check=True)
        print_success(f"VM '{name}' started!")

    print(f"\n{Colors.BOLD}VNC Connection Details:{Colors.ENDC}")
    print(f"  URL:  {Colors.OKGREEN}{vnc_url}{Colors.ENDC}")
    print(f"  Port: {meta['vnc_port']}")

    if not args.no_viewer:
        _launch_virt_viewer(vnc_url)


def cmd_qemu_stop(args: argparse.Namespace) -> None:
    svc = f"tailvm-{args.name}"
    print_info(f"Stopping VM '{args.name}' …")
    try:
        subprocess.run(
            ["systemctl", "--user", "--quiet", "stop", svc], check=True,
        )
        print_success(f"VM '{args.name}' stopped.")
    except subprocess.CalledProcessError:
        print_error(f"Failed to stop '{svc}' or it wasn't running.")


def cmd_qemu_list() -> None:
    if not BASE_DIR.exists():
        print_info("No local VMs found.")
        return
    vms: list[dict] = []
    for item in BASE_DIR.iterdir():
        if not item.is_dir() or item.name == "cache":
            continue
        meta_file = item / "metadata.json"
        if not meta_file.exists():
            continue
        try:
            meta = json.loads(meta_file.read_text())
            svc = f"tailvm-{meta['name']}"
            res = subprocess.run(
                ["systemctl", "--user", "is-active", svc],
                capture_output=True, text=True,
            )
            meta["status"] = res.stdout.strip()
            vms.append(meta)
        except Exception:
            pass

    if not vms:
        print_info("No registered local VMs.")
        return

    print(
        f"{Colors.BOLD}"
        f"{'VM NAME':<20} {'BACKEND':<10} {'STATUS':<10} {'VNC':<8} "
        f"{'CPU':<5} {'MEM':<6} {'DISK':<12} {'IP'}"
        f"{Colors.ENDC}"
    )
    print("-" * 85)
    for vm in vms:
        s = vm["status"]
        sc = (
            Colors.OKGREEN if s == "active"
            else Colors.FAIL if s == "failed"
            else Colors.ENDC
        )
        print(
            f"{vm['name']:<20} {'qemu':<10} {sc}{s}{Colors.ENDC:<4} "
            f"{vm['vnc_port']:<8} {vm['cpu']:<5} {vm['memory']:<6} "
            f"{vm['disk_size']:<12} {vm['tailscale_ip']}"
        )


def cmd_qemu_info(args: argparse.Namespace) -> None:
    name = args.name
    vm_dir = BASE_DIR / name
    if not vm_dir.exists():
        print_error(f"VM '{name}' does not exist!")
        sys.exit(1)
    meta = json.loads((vm_dir / "metadata.json").read_text())
    svc = f"tailvm-{name}"
    res = subprocess.run(
        ["systemctl", "--user", "status", svc],
        capture_output=True, text=True,
    )
    is_active = "active (running)" in res.stdout
    print(f"{Colors.BOLD}--- VM Info: {name} ---{Colors.ENDC}")
    print(f"Status:       {Colors.OKGREEN if is_active else Colors.FAIL}"
          f"{'Running' if is_active else 'Stopped/Inactive'}{Colors.ENDC}")
    print(f"Tailscale IP: {meta['tailscale_ip']}")
    print(f"VNC Port:     {meta['vnc_port']} (Display :{meta['vnc_display']})")
    print(f"VNC URL:      {Colors.OKGREEN}vnc://{meta['tailscale_ip']}:{meta['vnc_port']}{Colors.ENDC}")
    print(f"CPU Cores:    {meta['cpu']}")
    print(f"Memory:       {meta['memory']}")
    print(f"Disk Size:    {meta['disk_size']}")
    print(f"QCOW Base:    {meta.get('qcow_template') or 'None'}")
    print(f"ISO File:     {meta['iso'] or 'None'}")
    print(f"ISO Attached: {'Yes' if meta.get('has_iso') else 'No'}")
    print(f"Created:      {meta['created_at']}")
    print(f"\n{Colors.BOLD}Systemd Status snippet:{Colors.ENDC}")
    for line in res.stdout.split("\n")[:10]:
        print(f"  {line}")


def cmd_qemu_delete(args: argparse.Namespace) -> None:
    name = args.name
    vm_dir = BASE_DIR / name
    svc = f"tailvm-{name}"
    svc_path = SYSTEMD_USER_DIR / f"{svc}.service"

    if not vm_dir.exists() and not svc_path.exists():
        print_error(f"VM '{name}' does not exist!")
        sys.exit(1)

    print_info("Stopping and disabling service …")
    subprocess.run(["systemctl", "--user", "stop", svc], capture_output=True)
    subprocess.run(["systemctl", "--user", "disable", svc], capture_output=True)

    if svc_path.exists():
        svc_path.unlink()
        daemon_reload()
    if vm_dir.exists():
        shutil.rmtree(vm_dir)

    registry_remove(name)
    print_success(f"VM '{name}' deleted.")


def cmd_qemu_viewer(args: argparse.Namespace) -> None:
    vm_dir = BASE_DIR / args.name
    if not vm_dir.exists():
        print_error(f"VM '{args.name}' does not exist!")
        sys.exit(1)
    meta = json.loads((vm_dir / "metadata.json").read_text())
    _launch_virt_viewer(
        f"vnc://{meta['tailscale_ip']}:{meta['vnc_port']}"
    )


def cmd_qemu_eject(args: argparse.Namespace) -> None:
    name = args.name
    vm_dir = BASE_DIR / name
    svc = f"tailvm-{name}"
    svc_path = SYSTEMD_USER_DIR / f"{svc}.service"

    if not vm_dir.exists() or not svc_path.exists():
        print_error(f"VM '{name}' does not exist!")
        sys.exit(1)

    meta = json.loads((vm_dir / "metadata.json").read_text())
    if not meta.get("has_iso"):
        print_info("No ISO attached.")
        return

    print_info("Ejecting ISO …")
    meta["has_iso"] = False
    (vm_dir / "metadata.json").write_text(json.dumps(meta, indent=2))

    qemu_path, _ = find_qemu_binaries()
    svc_path.write_text(generate_systemd_unit(
        name=name, qemu_path=qemu_path,
        mem=meta["memory"], cpu=meta["cpu"],
        disk_path=str(vm_dir / "disk.qcow2"),
        iso_path=None, tailscale_ip=meta["tailscale_ip"],
        vnc_display=meta["vnc_display"], has_iso=False,
    ))
    daemon_reload()

    res = subprocess.run(
        ["systemctl", "--user", "is-active", svc],
        capture_output=True, text=True,
    )
    if res.stdout.strip() == "active":
        print_warning("VM is running. Restart it for changes to take effect.")
    else:
        print_success("CD-ROM ejected.")


def cmd_qemu_logs(args: argparse.Namespace) -> None:
    svc = f"tailvm-{args.name}"
    print_info(f"Logs for {svc}:")
    try:
        subprocess.run(["journalctl", "--user", "-u", svc, "-n", "50", "-f"])
    except KeyboardInterrupt:
        print()


def _launch_virt_viewer(vnc_url: str) -> None:
    """Spawn virt-viewer via flatpak if available."""
    print_info("Spawning virt-viewer …")
    flatpak = shutil.which("flatpak")
    if flatpak:
        subprocess.Popen(
            [flatpak, "run", "org.virt_manager.virt-viewer", vnc_url],
            stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
        )
        print_success("virt-viewer spawned!")
    else:
        print_warning("flatpak not found — cannot launch virt-viewer.")


