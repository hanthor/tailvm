def _random_password(length: int = 16) -> str:
    alphabet = string.ascii_letters + string.digits
    return "".join(secrets.choice(alphabet) for _ in range(length))


def _mem_to_mib(mem: str) -> int:
    mem = mem.upper()
    if mem.endswith("G"):
        return int(mem[:-1]) * 1024
    if mem.endswith("M"):
        return int(mem[:-1])
    return int(mem)


def generate_kubevirt_vm_manifest(
    name: str, namespace: str, cpu: int, mem: str,
    container_disk: str | None, pvc_name: str | None,
    disk_size: str | None, cloud_init_password: str | None,
) -> dict:
    mem_mib = _mem_to_mib(mem)
    domain: dict = {
        "cpu": {"cores": cpu},
        "memory": {"guest": f"{mem_mib}Mi"},
        "devices": {"disks": []},
    }
    volumes: list[dict] = []

    if container_disk:
        volumes.append({
            "name": "containerdisk",
            "containerDisk": {"image": container_disk},
        })
        domain["devices"]["disks"].append({
            "name": "containerdisk", "disk": {"bus": "virtio"},
        })
    elif pvc_name:
        volumes.append({
            "name": "rootdisk",
            "persistentVolumeClaim": {"claimName": pvc_name},
        })
        domain["devices"]["disks"].append({
            "name": "rootdisk", "disk": {"bus": "virtio"},
        })
    else:
        claim = f"{name}-disk"
        volumes.append({
            "name": "rootdisk",
            "persistentVolumeClaim": {"claimName": claim},
        })
        domain["devices"]["disks"].append({
            "name": "rootdisk", "disk": {"bus": "virtio"},
        })

    if disk_size and container_disk:
        volumes.append({
            "name": "datadisk",
            "persistentVolumeClaim": {"claimName": f"{name}-data"},
        })
        domain["devices"]["disks"].append({
            "name": "datadisk", "disk": {"bus": "virtio"},
        })

    pwd = cloud_init_password or _random_password()
    volumes.append({
        "name": "cloudinitdisk",
        "cloudInitNoCloud": {
            "userData": (
                "#cloud-config\n"
                f"password: {pwd}\n"
                "chpasswd:\n  expire: False\n"
                "ssh_pwauth: true\n"
            ),
        },
    })
    domain["devices"]["disks"].append({
        "name": "cloudinitdisk", "disk": {"bus": "virtio"},
    })

    return {
        "apiVersion": "kubevirt.io/v1",
        "kind": "VirtualMachine",
        "metadata": {
            "name": name, "namespace": namespace,
            "labels": {"tailvm": name},
        },
        "spec": {
            "running": False,
            "template": {
                "metadata": {"labels": {"kubevirt.io/vm": name}},
                "spec": {"domain": domain, "volumes": volumes},
            },
        },
    }


def generate_pvc_manifest(
    name: str, namespace: str, size: str,
    storage_class: str = "local-path",
) -> dict:
    return {
        "apiVersion": "v1",
        "kind": "PersistentVolumeClaim",
        "metadata": {
            "name": name, "namespace": namespace,
            "labels": {"tailvm": name.rsplit("-", 1)[0]},
        },
        "spec": {
            "accessModes": ["ReadWriteOnce"],
            "resources": {"requests": {"storage": size}},
            "storageClassName": storage_class,
        },
    }


