def cmd_kubevirt_create(args: argparse.Namespace) -> None:
    name = args.name
    ns = args.namespace or "default"
    password = args.cloud_init_password or _random_password()

    has_container = bool(args.container_disk)
    has_existing_pvc = bool(args.pvc)

    # Create PVCs
    if has_existing_pvc:
        pass
    elif has_container:
        if args.disk:
            pvc = generate_pvc_manifest(f"{name}-data", ns, args.disk)
            gum_spin(
                f"Creating data PVC {name}-data",
                ["kubectl", "apply", "-f", "-"],
                input=json.dumps(pvc), text=True, capture_output=True, check=True,
            )
            print_info(f"Data PVC: {name}-data ({args.disk})")
    else:
        disk_size = args.disk or "20G"
        pvc = generate_pvc_manifest(f"{name}-disk", ns, disk_size)
        gum_spin(
            f"Creating boot PVC {name}-disk",
            ["kubectl", "apply", "-f", "-"],
            input=json.dumps(pvc), text=True, capture_output=True, check=True,
        )
        print_info(f"Boot PVC: {name}-disk ({disk_size})")

    # Build and apply VM
    manifest = generate_kubevirt_vm_manifest(
        name=name, namespace=ns, cpu=args.cpu, mem=args.mem,
        container_disk=args.container_disk, pvc_name=args.pvc,
        disk_size=args.disk if has_container else None,
        cloud_init_password=password,
    )
    if args.node:
        manifest["spec"]["template"]["spec"]["nodeSelector"] = {
            "kubernetes.io/hostname": args.node,
        }

    gum_spin(
        f"Creating KubeVirt VM '{name}'",
        ["kubectl", "apply", "-f", "-"],
        input=json.dumps(manifest), text=True, capture_output=True, check=True,
    )

    registry_set(name, "kubevirt", {
        "namespace": ns,
        "cloud_init_password": password,
    })

    gum_print_header(f"VM '{name}' created in ns/{ns}")
    if not has_container:
        gum_section("Cloud-init password (save this!)")
        if GUM:
            subprocess.run([GUM, "style", "--foreground", "212", "--bold", "--border", "double", "--padding", "0 2", password])
        else:
            print(f"  {password}")
    print_info("Start it:  tailvm start " + name)


def cmd_kubevirt_start(args: argparse.Namespace) -> None:
    name = args.name or _interactive_name("start")
    ns = _kubevirt_namespace(name)
    virtctl = _ensure_virtctl()

    gum_spin(
        f"Starting KubeVirt VM '{name}'",
        [virtctl, "start", name, "-n", ns],
        check=True,
    )
    print_success(f"VM '{name}' started!")

    try:
        res = _kubectl(["get", "vmi", name, "-n", ns, "-o", "json"])
        if res.returncode == 0:
            vmi = json.loads(res.stdout)
            phase = vmi.get("status", {}).get("phase", "?")
            gum_kv("VMI phase", phase, "212" if "running" in phase.lower() else "255")
    except Exception:
        pass

    if not args.no_viewer:
        print_info(f"VNC:  virtctl vnc {name} -n {ns}")


def cmd_kubevirt_stop(args: argparse.Namespace) -> None:
