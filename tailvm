GUM = shutil.which("gum")

# Fallback ANSI colours (used when gum is not available)
_FALLBACK = {
    "fg":    "\033[38;5;255m",
    "green": "\033[92m",
    "cyan":  "\033[96m",
    "yellow":"\033[93m",
    "red":   "\033[91m",
    "bold":  "\033[1m",
    "dim":   "\033[2m",
    "reset": "\033[0m",
}


def _gum(*args: str, **kwargs) -> subprocess.CompletedProcess:
    """Run a gum command. Falls back gracefully if gum is not installed."""
    defaults = {"text": True}
    defaults.update(kwargs)
    return subprocess.run([GUM, *args], **defaults)  # type: ignore[arg-type]


def _gum_style(text: str, **flags) -> str:
    """Return text wrapped in gum style markup (or ANSI fallback)."""
    if GUM:
        return text  # gum style is used via subprocess, not inline
    # Build fallback ANSI
    pre = ""
    for flag, val in flags.items():
        if flag == "foreground" and val in _FALLBACK:
            pre += _FALLBACK[val]
        elif flag == "bold" and val:
            pre += _FALLBACK["bold"]
        elif flag == "faint" and val:
            pre += _FALLBACK["dim"]
    return f"{pre}{text}{_FALLBACK['reset']}" if pre else text


def gum_spin(title: str, cmd: list[str], **kwargs) -> subprocess.CompletedProcess:
    """Run *cmd* wrapped in a gum spinner with *title*."""
    if GUM:
        return subprocess.run(
            [GUM, "spin", "--title", title, "--"] + cmd,
            **kwargs,
        )
    # Fallback: just print the title and run
    print(f"{_FALLBACK['cyan']}⏳ {title}…{_FALLBACK['reset']}")
    return subprocess.run(cmd, **kwargs)


def gum_spin_shell(title: str, script: str, **kwargs) -> subprocess.CompletedProcess:
    """Run a shell script under a gum spinner."""
    if GUM:
        return subprocess.run(
            [GUM, "spin", "--title", title, "--", "bash", "-c", script],
            shell=False, **kwargs,
        )
    print(f"{_FALLBACK['cyan']}⏳ {title}…{_FALLBACK['reset']}")
    return subprocess.run(["bash", "-c", script], **kwargs)


def gum_table(headers: list[str], rows: list[list[str]]) -> None:
    """Render a table via gum table (or fallback to formatted print)."""
    if GUM and rows:
        csv = ",".join(headers) + "\n"
        for row in rows:
            csv += ",".join(str(c) for c in row) + "\n"
        try:
            subprocess.run(
                [GUM, "table", "--print"], input=csv, text=True,
            )
            return
        except Exception:
            pass  # fall through to fallback

    # Fallback: simple aligned print
    if not rows:
        return
    cols = len(headers)
    widths = [len(h) for h in headers]
    for row in rows:
        for i, cell in enumerate(row):
            widths[i] = max(widths[i], len(str(cell)))
    fmt = "  ".join(f"{{:<{w}}}" for w in widths)
    print(_FALLBACK["bold"] + fmt.format(*headers) + _FALLBACK["reset"])
    print("─" * (sum(widths) + 2 * (cols - 1)))
    for row in rows:
        print(fmt.format(*[str(c) for c in row]))


def gum_confirm(prompt: str, default: bool = False) -> bool:
    """Ask for confirmation. Returns True/False."""
    if GUM:
        args = [GUM, "confirm", prompt]
        if default:
            args.append("--default")
        res = subprocess.run(args, capture_output=False)
        return res.returncode == 0
    # Fallback
    yn = "Y/n" if default else "y/N"
    try:
        answer = input(f"{_FALLBACK['yellow']}? {prompt} [{yn}] {_FALLBACK['reset']}")
        return answer.lower().startswith("y") if default else answer.lower() == "y"
    except (KeyboardInterrupt, EOFError):
        return False


def gum_filter(choices: list[str], placeholder: str = "Select…") -> str:
    """Let the user pick one item from a fuzzy-filterable list."""
    if not GUM:
        # Fallback: numbered list
        for i, c in enumerate(choices, 1):
            print(f"  {i}. {c}")
        try:
            idx = int(input(f"{_FALLBACK['yellow']}> {_FALLBACK['reset']}")) - 1
            return choices[idx]
        except (ValueError, IndexError, KeyboardInterrupt):
            print()
            sys.exit(1)

    try:
        res = subprocess.run(
            [GUM, "filter", "--placeholder", placeholder],
            input="\n".join(choices), text=True, capture_output=True,
        )
        return res.stdout.strip()
    except KeyboardInterrupt:
        print()
        sys.exit(0)


